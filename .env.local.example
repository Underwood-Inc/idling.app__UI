API_NINJAS_KEY= api_key

# Development Settings
# Set to 'true' to bypass rate limiting in development
BYPASS_RATE_LIMIT=false

# Idling Radio PWA — Web Install API (navigator.install) origin trial token.
# Required for the radio dock "Install" button on production (Chrome / Edge 143+).
#
# Register the correct trial (NOT the HTML <install> element trial):
#   Chrome: https://developer.chrome.com/origintrials/#/view_trial/2367204554136616961
#   Edge:   https://developer.microsoft.com/en-us/microsoft-edge/origin-trials/trials/bcf7d28f-6bdf-45d8-9207-63c97a042407
#   Look for: "WebAppInstallation" / imperative install via install_url + manifest_id
#
# Registration:
#   1. Sign in (Google on Chrome portal, GitHub on Edge portal).
#   2. Web origin: https://idling.app  (no trailing slash; use https://)
#   3. Optional: check "subdomains" only if you also serve from www.idling.app etc.
#   4. Copy the token string after Register — paste below (no quotes).
#   5. Rebuild and redeploy (NEXT_PUBLIC_* is read at build time).
#   6. Verify: DevTools → Elements → <head> has <meta http-equiv="origin-trial" …>
#      and console: typeof navigator.install === "function"
#
# Local dev without a token: Chrome/Edge → edge://flags or chrome://flags →
#   search "Web App Installation API" → Enabled, then restart browser.
#
# NEXT_PUBLIC_WEB_INSTALL_ORIGIN_TRIAL_TOKEN=