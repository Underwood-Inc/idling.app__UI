{
  "name": "idling.app",
  "version": "0.498.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "engineStrict": true,
  "scripts": {
    "setup:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-windows.ps1",
    "build": "next build --webpack",
    "prebuild": "node scripts/update-sw-version.js",
    "postbuild": "node scripts/update-sw-version.js --restore",
    "dev:docker": "./scripts/docker-dev.sh",
    "dev:docker:win": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-dev.ps1",
    "dev:docker:up": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:seed": "node seed-db-faker.js",
    "dev": "next dev",
    "docs:dev": "docusaurus start --port 3001 --host 0.0.0.0",
    "docs:build": "docusaurus build",
    "docs:serve": "docusaurus serve --port 3001",
    "docs:clear": "docusaurus clear",
    "docs:audit": "node scripts/docs-automation.js audit",
    "docs:fix": "node scripts/docs-automation.js fix",
    "docs:standardize": "node scripts/docs-automation.js standardize",
    "docs:validate": "node scripts/docs-automation.js validate",
    "docs:doctor": "node scripts/docs-automation.js doctor",
    "sw:update": "node scripts/update-sw-version.js",
    "sw:restore": "node scripts/update-sw-version.js --restore",
    "docs:install": "echo 'Jekyll removed - use pnpm install for Docusaurus'",
    "docs:coverage": "python3 scripts/check-docs-coverage.py --format html",
    "docs:coverage:syntax": "python3 scripts/check-docs-coverage.py --format html",
    "docs:openapi": "node scripts/generate-openapi-spec.js",
    "e2e:gen": "pnpm playwright codegen",
    "e2e:headed": "pnpm playwright test --headed",
    "e2e:headless": "pnpm playwright test",
    "e2e:reports": "pnpm playwright show-report",
    "e2e:docker": "./scripts/run-e2e-docker.sh",
    "e2e": "pnpm playwright test --ui",
    "gen:secret": "openssl rand -base64 32",
    "lint-staged": "lint-staged",
    "validate": "pnpm lint && pnpm lint:css && pnpm lint:css:vars",
    "lint": "npx tsc --noemit --project tsconfig.json",
    "lint:css": "stylelint \"src/**/*.{css,scss,module.css}\" --cache",
    "lint:css:fix": "stylelint \"src/**/*.{css,scss,module.css}\" --fix --cache",
    "lint:css:vars": "node scripts/validate-css-variables.js",
    "build:radio-widget-embed": "tsc -p src/widgets/radio-player/tsconfig.embed.json",
    "migrations": "tsx scripts/migrations.ts main",
    "migrate:og-table": "node scripts/run-migration.js",
    "test:og-tracking": "node scripts/test-og-tracking.js",
    "migrate:og-generations": "node scripts/run-migration.js",
    "manage-user": "node scripts/manage-user.js",
    "explore-db": "node scripts/explore-db.js",
    "go:install": "./scripts/install-go.sh",
    "go:install:force": "./scripts/install-go.sh --force",
    "go:install:user": "./scripts/install-go.sh --user",
    "go:version": "./scripts/setup-go-env.sh go version",
    "tui:build": "./scripts/setup-go-env.sh ./cmd/manage-user/build.sh",
    "tui:build:clean": "./scripts/setup-go-env.sh ./cmd/manage-user/build.sh --clean-before-build",
    "tui:build:verbose": "./scripts/setup-go-env.sh ./cmd/manage-user/build.sh --verbose",
    "tui:run": "pnpm tui:rebuild && ./scripts/setup-go-env.sh ./cmd/manage-user/manage-user-tui",
    "tui:clean": "./scripts/setup-go-env.sh ./cmd/manage-user/build.sh --clean",
    "tui:rebuild": "pnpm tui:clean && pnpm tui:build",
    "prepare": "husky",
    "prettier": "prettier --write .",
    "release": "release-it",
    "start": "next start",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:to-file": "vitest run --reporter=json --outputFile=test-results.json",
    "version:bump": "node scripts/version-bump.js",
    "version:test": "node scripts/version-bump-from-msg.js --test",
    "version:demo": "node scripts/version-bump-from-msg.js --test \"feat: example feature for demo\"",
    "version:help": "node scripts/version-bump-from-msg.js --test \"help\"",
    "debug:parser": "node debug-content-parser.js",
    "debug:parser:interactive": "node debug-content-parser.js --interactive",
    "debrief": "node scripts/generate-feature-debrief.js",
    "clad:audit": "clad-audit audit --root . --preset structure --depth standard",
    "clad:audit:full": "clad-audit audit --root . --preset full --depth standard --verbose",
    "clad:report": "clad-audit audit --root . --preset exhaustive --report clad-report.md"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/pg-adapter": "^1.11.2",
    "@axe-core/playwright": "^4.11.3",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@dicebear/collection": "9.4.2",
    "@dicebear/core": "^9.4.2",
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@napi-rs/canvas": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "audiomotion-analyzer": "^4.5.4",
    "buffer": "^6.0.3",
    "canvas-prebuilt": "npm:@napi-rs/canvas@^1.0.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "docusaurus-plugin-sass": "^0.2.6",
    "docusaurus-plugin-search-local": "^2.1.2",
    "dotenv": "^17.4.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "highlight.js": "^11.11.1",
    "hls.js": "~1.6.16",
    "jose": "^6.2.3",
    "jotai": "2.20.1",
    "lorem-ipsum": "^3.0.0",
    "lucide": "~1.16.0",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.22.0",
    "postgres": "3.4.9",
    "prism-react-renderer": "^2.4.1",
    "process": "^0.11.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-spinners": "^0.17.0",
    "react-string-replace": "^2.0.1",
    "redocusaurus": "^2.5.0",
    "sass": "^1.101.0",
    "stream-browserify": "^3.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-react": "^5.32.6",
    "utf-8-validate": "^6.0.6",
    "util": "^0.12.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^26.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@underwoodinc/clad-audit": "^0.4.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.6",
    "auto-changelog": "^2.6.0",
    "chalk": "^5.6.2",
    "css-loader": "^7.1.4",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-custom-rules": "file:custom-eslint-rules",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "js-yaml": "^5.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.7",
    "playwright-core": "^1.61.0",
    "prettier": "^3.8.4",
    "prompts": "^2.4.2",
    "release-it": "^20.2.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@11.8.0",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{css,scss,module.css}": [
      "stylelint --fix --cache",
      "node scripts/validate-css-variables.js"
    ]
  }
}